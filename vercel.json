{
  "outputDirectory": "docs",
  "functions": {
    "api/today.js": { "maxDuration": 120 },
    "api/atenti-search.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
